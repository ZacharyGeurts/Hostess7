#!/bin/bash
# NEXUS-Shield operator CLI — read-only for nexus group; admin via install only.
set -euo pipefail

NEXUS_INSTALL_ROOT="${NEXUS_INSTALL_ROOT:-/usr/local/lib/nexus-shield}"
_script_root="$(cd "$(dirname "$0")/.." && pwd)"
if [[ -f "${_script_root}/lib/nexus-common.sh" ]]; then
  NEXUS_INSTALL_ROOT="$_script_root"
fi

# shellcheck source=/dev/null
source "${NEXUS_INSTALL_ROOT}/lib/nexus-common.sh"

if ! nexus_operator_authorized; then
  cat >&2 <<EOF
nexus: access denied (not in group ${NEXUS_GROUP}).

Run once:  sudo ./stealth_install.sh
Then either log out/in, or use:  sg ${NEXUS_GROUP} -c 'nexus status'
EOF
  exit 1
fi

# shellcheck source=/dev/null
source "${NEXUS_INSTALL_ROOT}/lib/eternal-vigil.sh"
# shellcheck source=/dev/null
source "${NEXUS_INSTALL_ROOT}/lib/shadow-reality.sh"

nexus_load_config

nexus_require_install_for_admin() {
  cat >&2 <<EOF
nexus ${1}: admin action — re-run the installer instead of sudo:

  sudo ./stealth_install.sh
EOF
  exit 1
}

usage() {
  cat <<'EOF'
NEXUS-Shield CLI — full control if the browser won't open
  nexus status              Vigil mode, firewall, panel URL
  nexus verify              Script integrity manifest
  nexus alerts              Tail unified alert log
  nexus entropy <file>      Score file entropy
  nexus test                Run test suite
  nexus panel               Open panel (browser detection)
  nexus panel --url         Print panel URL only
  nexus panel --wait        Wait until panel responds
  nexus panel --no-browser  Print URL + CLI help (no browser)
  nexus connections         List scored live connections (JSON)
  nexus trust <ip> [label]  Trust forever (allow outbound)
  nexus block <ip>          Block for 1 day
  nexus block <ip> --forever
  nexus unblock <ip>        Unblock for 1 day (temp allow)
  nexus scour               Classify active vectors (never unknown)
  nexus intel <ip>          Look up peer intelligence
  nexus eradicate <ip> [pid]  Remove host pest (block + stop + quarantine)
  nexus field status          Whole system on field drive — status JSON
  nexus field publish         Copy whole NEXUS install + state to field drive
  nexus field talk <json>     Talk to field drive (connect/probe/publish)
  nexus field panel           Full GUI URL (/field) — field-talk redirects here
  nexus antenna status        Field antenna blaster readiness JSON
  nexus antenna cycle         Full detect cycle (RF, audio, laser, BLE, sub-µm)
  nexus antenna test          Blaster readiness test
  nexus antenna launch [N]    Restart cycles until blaster_ready (default 12)
  nexus dossier             Angel dossiers — attack paths (JSON)
  nexus research            Research tables — MAC/CVE/MITRE (JSON)
  nexus paranoia            Paranoia mode status
  nexus shutdown            Shutdown guard / restart

Admin: sudo ./stealth_install.sh
Panel: https://127.0.0.1:9477/  (or: ./nexus.sh)
EOF
}

cmd="${1:-}"
sub="${2:-}"

case "$cmd" in
  status)
    [[ -r "$NEXUS_VIGIL_STATE" ]] || {
      echo "nexus status: cannot read ${NEXUS_VIGIL_STATE} (is nexus-genius.service running?)" >&2
      exit 1
    }
    echo "mode=$(nexus_vigil_get_mode)"
    echo "scan_interval=$(nexus_vigil_scan_interval)s"
    echo "entropy_threshold=$(nexus_vigil_entropy_threshold)"
    echo "recent_alerts=$(nexus_vigil_count_recent 600)"
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/firewall-sentinel.sh"
    nexus_firewall_status
    echo "panel=http://127.0.0.1:${NEXUS_THREAT_PANEL_PORT:-9477}/field"
    # shellcheck source=/dev/null
    [[ -f "${NEXUS_INSTALL_ROOT}/lib/znetwork-field.sh" ]] && source "${NEXUS_INSTALL_ROOT}/lib/znetwork-field.sh"
    declare -f nexus_znetwork_status_line >/dev/null 2>&1 && nexus_znetwork_status_line
    ;;
  shadow)
    nexus_require_install_for_admin "shadow ${sub:-}"
    ;;
  sign)
    nexus_require_install_for_admin "sign"
    ;;
  verify)
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/self-defense.sh"
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/seal-vault.sh"
    ok=0
    nexus_verify_integrity && echo "integrity=OK" || { echo "integrity=FAIL"; ok=1; }
    if [[ "$(id -u)" -eq 0 ]]; then
      if nexus_seal_verify 2>/dev/null; then
        echo "seal=OK"
      else
        echo "seal=missing_or_fail"
        ok=1
      fi
    else
      echo "seal=protected"
    fi
    [[ "$ok" -eq 0 ]]
    ;;
  entropy)
    file="${sub:-}"
    [[ -n "$file" && -f "$file" ]] || { echo "usage: nexus entropy <file>"; exit 1; }
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/entropy-oracle.sh"
    echo "$(nexus_entropy_score "$file")"
    ;;
  test)
    exec "${NEXUS_INSTALL_ROOT}/tests/run-tests.sh"
    ;;
  alerts)
    tail -n 50 "$NEXUS_ALERT_LOG" 2>/dev/null || echo "No alerts yet."
    ;;
  shutdown)
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/shutdown-guard.sh"
    case "${sub:-status}" in
      status)
        nexus_shutdown_status_json
        echo ""
        ;;
      restart)
        nexus_shutdown_restart "${3:-block}" "${4:-}"
        ;;
      incidents)
        nexus_shutdown_recent_json "${3:-10}"
        ;;
      *)
        echo "usage: nexus shutdown [status|restart block|permissive [offender_ip]|incidents]"
        exit 1
        ;;
    esac
    ;;
  paranoia)
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/firewall-sentinel.sh"
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/threat-vectors.sh"
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/packet-oracle.sh"
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/paranoia-mode.sh"
    case "${sub:-status}" in
      status)
        nexus_paranoia_status_json
        echo ""
        ;;
      block)
        case "${3:-off}" in
          on|1|true) nexus_paranoia_set_block 1 ;;
          *) nexus_paranoia_set_block 0 ;;
        esac
        nexus_paranoia_status_json
        ;;
      incidents)
        nexus_paranoia_recent_json "${3:-15}"
        ;;
      *)
        echo "usage: nexus paranoia [status|block on|block off|incidents [n]]"
        exit 1
        ;;
    esac
    ;;
  panel)
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/panel-browser.sh"
    flag="${sub:-}"
    url="$(nexus_panel_url)"
    case "$flag" in
      --url) echo "$url" ;;
      --wait)
        if nexus_panel_wait_ready "$url" 45; then echo "Panel ready: $url"; else exit 1; fi
        ;;
      --no-browser)
        nexus_panel_wait_ready "$url" 20 || true
        nexus_panel_open_help "$url"
        ;;
      *)
        echo "Panel: $url"
        browsers="$(nexus_panel_detect_browsers | tr '\n' ' ')"
        echo "Browsers detected: ${browsers:-none}"
        if ! nexus_panel_open_browser "$url"; then
          nexus_panel_open_help "$url" >&2
          exit 1
        fi
        ;;
    esac
    ;;
  connections)
    json="${NEXUS_STATE_DIR}/connection-intent.json"
    if [[ ! -s "$json" ]]; then
      json="${NEXUS_STATE_DIR}/threat-panel.json"
      if [[ -s "$json" ]]; then
        pythong -c "import json,sys; d=json.load(open(sys.argv[1])); print(json.dumps(d.get('gatekeeper',{}), indent=2))" "$json" 2>/dev/null \
          || echo '{"connections":[]}'
        exit 0
      fi
      echo '{"connections":[],"error":"gatekeeper warming up"}'
      exit 0
    fi
    cat "$json"
    ;;
  trust)
    ip="${sub:-}"
    label="${3:-cli}"
    [[ -n "$ip" ]] || { echo "usage: nexus trust <ip> [label]"; exit 1; }
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/firewall-trust.sh"
    nexus_firewall_authorize_ip "$ip" out "$label" "nexus-cli" && echo "trusted ${ip}" || exit 1
    ;;
  block)
    ip="${sub:-}"
    forever=0
    [[ "${3:-}" == "--forever" ]] && forever=1
    [[ -n "$ip" ]] || { echo "usage: nexus block <ip> [--forever]"; exit 1; }
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/firewall-sentinel.sh"
    if [[ "$forever" -eq 1 ]]; then
      nexus_firewall_block_ip_forever out "$ip" "nexus-cli" && echo "blocked forever ${ip}"
    else
      nexus_firewall_block_ip out "$ip" "${NEXUS_FIREWALL_BLOCK_DURATION:-86400}" "nexus-cli" && echo "blocked 1 day ${ip}"
    fi
    ;;
  unblock)
    ip="${sub:-}"
    [[ -n "$ip" ]] || { echo "usage: nexus unblock <ip>"; exit 1; }
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/firewall-sentinel.sh"
    nexus_firewall_temp_allow_ip out "$ip" "${NEXUS_FIREWALL_TEMP_ALLOW_DURATION:-86400}" && echo "unblocked 1 day ${ip}"
    ;;
  scour)
    script="${NEXUS_INSTALL_ROOT}/lib/vector-intel.py"
    [[ -f "$script" ]] || { echo "vector-intel missing"; exit 1; }
    NEXUS_STATE_DIR="$NEXUS_STATE_DIR" NEXUS_INSTALL_ROOT="$NEXUS_INSTALL_ROOT" \
      pythong "$script" scour
    ;;
  intel)
    ip="${sub:-}"
    [[ -n "$ip" ]] || { echo "usage: nexus intel <ip>"; exit 1; }
    script="${NEXUS_INSTALL_ROOT}/lib/vector-intel.py"
    [[ -f "$script" ]] || { echo "vector-intel missing"; exit 1; }
    NEXUS_STATE_DIR="$NEXUS_STATE_DIR" NEXUS_INSTALL_ROOT="$NEXUS_INSTALL_ROOT" \
      pythong "$script" lookup "$ip"
    ;;
  dossier)
    script="${NEXUS_INSTALL_ROOT}/lib/angel-dossier.py"
    [[ -f "$script" ]] || { echo '{"dossiers":[]}'; exit 0; }
    NEXUS_STATE_DIR="$NEXUS_STATE_DIR" NEXUS_INSTALL_ROOT="$NEXUS_INSTALL_ROOT" \
      pythong "$script" dossiers
    ;;
  research)
    script="${NEXUS_INSTALL_ROOT}/lib/angel-dossier.py"
    [[ -f "$script" ]] || { echo '{"tables":{}}'; exit 0; }
    NEXUS_STATE_DIR="$NEXUS_STATE_DIR" NEXUS_INSTALL_ROOT="$NEXUS_INSTALL_ROOT" \
      pythong "$script" research
    ;;
  antenna)
    action="${sub:-status}"
    apy="${NEXUS_INSTALL_ROOT}/lib/field-antenna-orchestrator.py"
    launcher="${NEXUS_INSTALL_ROOT}/lib/field-antenna-launcher.sh"
    [[ -f "$apy" ]] || { echo "field-antenna-orchestrator missing"; exit 1; }
    case "$action" in
      status)
        NEXUS_STATE_DIR="$NEXUS_STATE_DIR" NEXUS_INSTALL_ROOT="$NEXUS_INSTALL_ROOT" \
          pythong "$apy" json
        ;;
      cycle)
        NEXUS_STATE_DIR="$NEXUS_STATE_DIR" NEXUS_INSTALL_ROOT="$NEXUS_INSTALL_ROOT" \
          pythong "$apy" cycle
        ;;
      test)
        NEXUS_STATE_DIR="$NEXUS_STATE_DIR" NEXUS_INSTALL_ROOT="$NEXUS_INSTALL_ROOT" \
          pythong "$apy" test
        ;;
      launch|blaster)
        max="${3:-12}"
        if [[ -x "$launcher" ]]; then
          NEXUS_STATE_DIR="$NEXUS_STATE_DIR" NEXUS_INSTALL_ROOT="$NEXUS_INSTALL_ROOT" \
            "$launcher" launch "$max"
        else
          NEXUS_STATE_DIR="$NEXUS_STATE_DIR" NEXUS_INSTALL_ROOT="$NEXUS_INSTALL_ROOT" \
            pythong "$apy" launch "$max"
        fi
        ;;
      *)
        echo "usage: nexus antenna [status|cycle|test|launch [max_rounds]]"
        exit 1
        ;;
    esac
    ;;
  field)
    action="${sub:-status}"
    fpy="${NEXUS_INSTALL_ROOT}/lib/field-drive-system.py"
    [[ -f "$fpy" ]] || { echo "field-drive-system missing"; exit 1; }
    case "$action" in
      status)
        NEXUS_STATE_DIR="$NEXUS_STATE_DIR" NEXUS_INSTALL_ROOT="$NEXUS_INSTALL_ROOT" \
          pythong "$fpy" status
        ;;
      publish)
        NEXUS_STATE_DIR="$NEXUS_STATE_DIR" NEXUS_INSTALL_ROOT="$NEXUS_INSTALL_ROOT" \
          pythong "$fpy" publish
        ;;
      sync)
        NEXUS_STATE_DIR="$NEXUS_STATE_DIR" NEXUS_INSTALL_ROOT="$NEXUS_INSTALL_ROOT" \
          pythong "$fpy" sync
        ;;
      talk)
        payload="${3:-"{}"}"
        [[ -n "$payload" ]] || payload='{"op":"status"}'
        NEXUS_STATE_DIR="$NEXUS_STATE_DIR" NEXUS_INSTALL_ROOT="$NEXUS_INSTALL_ROOT" \
          pythong "$fpy" talk "$payload"
        ;;
      panel)
        port="${NEXUS_THREAT_PANEL_PORT:-9477}"
        echo "https://127.0.0.1:${port}/field"
        ;;
      *)
        echo "usage: nexus field [status|publish|sync|talk JSON|panel]"
        exit 1
        ;;
    esac
    ;;
  eradicate)
    ip="${sub:-}"
    pid="${3:-0}"
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/firewall-sentinel.sh"
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/firewall-trust.sh"
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/self-access.sh"
    # shellcheck source=/dev/null
    source "${NEXUS_INSTALL_ROOT}/lib/pest-arsenal.sh"
    [[ -n "$ip" ]] || { echo "usage: nexus eradicate <ip> [pid]"; exit 1; }
    nexus_pest_eradicate "$ip" "$pid" "CLI_HARM" "" && echo "eradicated ${ip}" || exit 1
    ;;
  *)
    usage
    exit 1
    ;;
esac
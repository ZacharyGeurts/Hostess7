{
  "schema": "zocr-mouth-neural-assist/v1",
  "network_id": "FINAL_MOUTH_ASSIST_v1",
  "rule": "Field neural voice hemisphere — thought and utterance are separate; deception is possible; callosum binds under Hostess 7 truth gate",
  "hemisphere": "voice_egress",
  "thought_hemisphere": "internal_intent",
  "encourage": true,
  "truth_floor": 58,
  "labels": [
    "honest_speech",
    "text_to_voice",
    "diplomatic_gap",
    "ventriloquism",
    "thought_mask",
    "ai_sound_communique"
  ],
  "cross_wire": {
    "from_ear": ["speech_present", "ventriloquism_hint", "mouth_correlation"],
    "from_eye": ["mouth_viseme", "existence_bearing", "rf_lie_score"],
    "to_ear": ["utterance_energy", "viseme_bind", "phantom_reject"],
    "to_eye": ["lip_sync_score", "voice_origin", "deception_risk"]
  },
  "training_lessons": [
    {"id": "text_to_speech", "label": "Text → speech render path"},
    {"id": "thought_voice_gap", "label": "Thought hemisphere ≠ voice hemisphere"},
    {"id": "ai_sound_communique", "label": "AI communicates with sound — local egress only"},
    {"id": "deception_discern", "label": "Mouth may not mirror inner thought — Neural Guardian cross-check"},
    {"id": "speaking_phonetics", "label": "Read IPA from Exploring Speaking book"},
    {"id": "speaking_lemma_speak", "label": "Speak dictionary lemma through glottis"},
    {"id": "speaking_human_spoken_word", "label": "Human intelligibility band — FCC acoustic safe"},
    {"id": "speaking_animal_call", "label": "Animal audience bands — dog, cat, horse, bird"},
    {"id": "speaking_hieroglyph_translit", "label": "Hieroglyph transliteration → spoken gloss"},
    {"id": "speaking_thought_voice_speak", "label": "Thought → voice hemisphere → Final Mouth speak"}
  ],
  "fcc_acoustic": "data/final-mouth-fcc-acoustic.json",
  "spoken_word_first": true,
  "default_audience": "human",
  "layers": [
    {"id": "features", "in": 12, "out": 12, "activation": "identity"},
    {
      "id": "hidden",
      "in": 12,
      "out": 6,
      "activation": "relu",
      "weights": [
        [0.16, -0.08, 0.19, 0.07, -0.11, 0.14, 0.09, -0.06, 0.12, 0.05, -0.10, 0.17],
        [-0.06, 0.15, 0.04, -0.12, 0.18, -0.07, 0.11, 0.08, -0.14, 0.09, 0.05, -0.03],
        [0.09, -0.11, 0.16, 0.05, -0.04, 0.18, -0.13, 0.10, 0.03, -0.08, 0.17, 0.12],
        [0.13, 0.01, -0.09, 0.18, 0.04, -0.12, 0.09, -0.07, 0.15, 0.02, -0.14, 0.06],
        [-0.08, 0.12, 0.08, -0.16, 0.07, 0.03, -0.11, 0.17, -0.05, 0.10, 0.13, -0.02],
        [0.11, -0.05, 0.16, -0.09, 0.12, 0.05, -0.14, 0.02, 0.18, -0.10, 0.04, 0.11]
      ],
      "bias": [0.01, -0.01, 0.02, 0.0, -0.01, 0.01]
    },
    {
      "id": "output",
      "in": 6,
      "out": 6,
      "activation": "softmax",
      "labels": [
        "honest_speech",
        "text_to_voice",
        "diplomatic_gap",
        "ventriloquism",
        "thought_mask",
        "ai_sound_communique"
      ],
      "weights": [
        [0.19, -0.08, 0.13, 0.06, -0.10, 0.15],
        [-0.06, 0.17, 0.04, -0.12, 0.09, 0.02],
        [0.10, 0.03, -0.09, 0.18, -0.04, 0.12],
        [0.07, -0.13, 0.16, 0.01, 0.14, -0.06],
        [-0.09, 0.06, 0.11, -0.05, 0.17, 0.08],
        [0.12, -0.04, 0.07, 0.15, -0.03, 0.10]
      ],
      "bias": [0, 0, 0, 0, 0, 0]
    }
  ]
}
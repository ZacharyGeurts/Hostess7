  grep -q 'qf-search' "${ROOT}/Queen/world/queen-files.html"
  [[ -f "${ROOT}/Queen/world/queen-syntax.css" ]]
  [[ -f "${ROOT}/Queen/world/queen-viewer.js" ]]

test_field_os_shell() {
  [[ -f "${ROOT}/lib/field-shell-settings.py" ]]
  [[ -f "${ROOT}/panel/assets/nexus-field-shell.js" ]]
  [[ -f "${ROOT}/panel/assets/nexus-field-shell.css" ]]
  [[ -f "${ROOT}/panel/assets/field-queen-nav.js" ]]
  [[ -f "${ROOT}/panel/control-panel.html" ]]
  [[ -f "${ROOT}/panel/assets/control-panel.js" ]]
  grep -q 'FieldC2TaskManager' "${ROOT}/panel/field-desktop.html"
  grep -q 'data-ammoos-desktop="1"' "${ROOT}/panel/field-desktop.html"
  grep -q 'bindDesktopContextMenu' "${ROOT}/panel/assets/nexus-field-shell.js"
  grep -q 'isAmmoOSDesktop' "${ROOT}/Queen/world/queen-page-agent.js"
  grep -q 'isAmmoOSFrame' "${ROOT}/Queen/world/queen-page-inspector.js"

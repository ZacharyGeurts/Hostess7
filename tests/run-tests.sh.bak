test_kilroy_kernel_grok16() {
  [[ -f "${ROOT}/KILROY/scripts/kilroy-kernel-test.sh" ]]
  [[ -f "${ROOT}/KILROY/scripts/kilroy-grok16-sync.sh" ]]
  [[ -f "${ROOT}/KILROY/data/kilroy-grok16-bridge.json" ]]
  [[ -f "${ROOT}/KILROY/scripts/kilroy-toolchain.sh" ]]
  grep -q 'grok16_pair' "${ROOT}/KILROY/data/kilroy-version.json"
  grep -q 'kilroy-kernel-test' "${ROOT}/KILROY/data/kilroy-grok16-bridge.json"
  grep -q 'sync_kilroy' "${SG_ROOT:-$(cd "${ROOT}/.." && pwd)}/Grok16/scripts/grok16-integrate.sh"
  grep -q 'grok16_bridge' "${ROOT}/Queen/lib/queen-kilroy.py"
  grep -q '"default_mode": "war"' "${ROOT}/KILROY/data/kilroy-ai-mandate.json"
  grep -q 'war_posture_always' "${ROOT}/KILROY/data/kilroy-ai-mandate.json"
  grep -q 'KILROY_AI_MODE_WAR' "${ROOT}/KILROY/kernel/rtx/kilroy_ai_field.c"
  grep -q 'war_posture_always' "${ROOT}/data/kilroy-core-doctrine.json"
  grep -q 'KILROY_WAR_POSTURE=1' "${ROOT}/config/nexus.conf"
  grep -q 'KILROY_KERNEL_UNLOCKED=1' "${ROOT}/config/nexus.conf"
  grep -q 'KILROY_DEFENSIVE_ONLY=1' "${ROOT}/config/nexus.conf"
  grep -q 'KILROY_HOSTILE_INSIDE=0' "${ROOT}/config/nexus.conf"
  grep -q 'infrastructure_sanctuary' "${ROOT}/KILROY/data/kilroy-perimeter-war-doctrine.json"
  grep -q 'KILROY_SELF_HARM_FORBIDDEN=1' "${ROOT}/config/nexus.conf"
  grep -q 'hostile_inside_network' "${ROOT}/KILROY/data/kilroy-perimeter-war-doctrine.json"
  grep -q 'KILROY_AI_KERNEL_UNLOCKED' "${ROOT}/KILROY/kernel/rtx/kilroy_ai_wishes.h"
  chmod +x "${ROOT}/KILROY/scripts/kilroy-kernel-test.sh" \
    "${ROOT}/KILROY/scripts/kilroy-grok16-sync.sh" \
    "${ROOT}/KILROY/scripts/kilroy-toolchain.sh" \
    "${ROOT}/KILROY/scripts/test-grok16-kilroy-userspace.sh" 2>/dev/null || true
  KILROY_ENHANCED=0 FULL_BUILD=0 GROK_FULL_BUILD=0 AML_BUILD=0 AML_INLINE=1 \
    KILROY_KERNEL_TEST=1 KILROY_AI_MODE=war \
    SG_ROOT="${SG_ROOT:-$(cd "${ROOT}/.." && pwd)}" \
    NEXUS_INSTALL_ROOT="${ROOT}" \
    GROK16_ROOT="${SG_ROOT:-$(cd "${ROOT}/.." && pwd)}/Grok16" \
    CC=/usr/bin/gcc HOSTCC=/usr/bin/gcc PATH="/usr/bin:/bin:${PATH}" \
    bash "${ROOT}/KILROY/scripts/kilroy-kernel-test.sh"
}

run_test "kilroy kernel grok16 regression" test_kilroy_kernel_grok16


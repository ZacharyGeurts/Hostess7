# AmmoOS Image sessionrc
# 
# This file takes session-specific info (that is info, you want to keep
# between two AmmoOS Image sessions).  You are not supposed to edit it manually, but
# of course you can do.  The sessionrc will be entirely rewritten every time
# you quit AmmoOS Image.  If this file isn't found, defaults are used.

(session-info "toplevel"
    (factory-entry "ammoos-empty-image-window")
    (position 200 100)
    (size 640 480))
(session-info "toplevel"
    (factory-entry "ammoos-single-image-window")
    (position 0 0)
    (size 800 600)
    (open-on-exit)
    (aux-info
        (left-docks-width "188")
        (right-docks-width "205")
        (maximized "no"))
    (ammoos-toolbox
        (side left)
        (book
            (current-page 0)
            (dockable "ammoos-tool-options"
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))
            (dockable "ammoos-device-status"
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))
            (dockable "ammoos-undo-history"
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))
            (dockable "ammoos-image-list"
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))))
    (ammoos-dock
        (side right)
        (book
            (current-page 0)
            (dockable "ammoos-brush-grid"
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))
            (dockable "ammoos-pattern-grid"
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))
            (dockable "ammoos-font-list"
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true")))
            (dockable "ammoos-document-list"
                (tab-style automatic)
                (aux-info
                    (show-button-bar "true"))))
        (book
            (position 336)
            (current-page 0)
            (dockable "ammoos-layer-list"
                (tab-style automatic)
                (preview-size 32)
                (aux-info
                    (show-button-bar "true")))
            (dockable "ammoos-channel-list"
                (tab-style automatic)
                (preview-size 32)
                (aux-info
                    (show-button-bar "true")))
            (dockable "ammoos-path-list"
                (tab-style automatic)
                (preview-size 32)
                (aux-info
                    (show-button-bar "true"))))))

(hide-docks no)
(single-window-mode yes)
(tabs-position 0)
(last-tip-shown 0)

# end of sessionrc

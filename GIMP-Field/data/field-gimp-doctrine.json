{
  "schema": "ammoos-gimp-doctrine/v1",
  "title": "AmmoOS Image 1.0 — Field Research rewrite of GIMP",
  "product": "AmmoOS Image",
  "version": "1.0.0",
  "os_brand": "AmmoOS",
  "motto": "Field imaging inside AmmoOS — g16 field_opt everywhere; RTX paths autodetected and gated for operator protection.",
  "upstream": {
    "path": "GIMP",
    "tree": "GIMP-Field/tree",
    "remote": "https://gitlab.gnome.org/GNOME/gimp",
    "license": "GPL-3.0+",
    "sync": "GIMP-Field/forge/clone-upstream.sh"
  },
  "field_mandate": {
    "g16": "G16_FIELD_SAFETY_MANDATE_v1",
    "default_profile": "field_opt",
    "rtx_profile": "queen_rtx",
    "no_client_browser": true,
    "queen_browser_only": true,
    "sovereign_time": true,
    "thermal_honesty": true,
    "packet_receipts_on_export": true,
    "rtx_gate_module": "Grok16/forge/rtx_gate.py"
  },
  "rtx_policy": {
    "autodetect": true,
    "fallback_profile": "field_opt",
    "gated_profiles": ["queen_rtx", "vulkan_rtx"],
    "override_env": "G16_RTX_GATE_FORCE",
    "operator_message": "RTX-class GPU not detected — CPU field_opt path active; gated tools hidden.",
    "manifest": "GIMP-Field/data/rtx-gated-content.json"
  },
  "rewrite_phases": [
    {
      "id": "phase-0-foundation",
      "label": "Clone upstream · doctrine · bridge · meson g16 overlay",
      "status": "complete",
      "paths": ["GIMP-Field", "NewLatest/lib/field-gimp-bridge.py"]
    },
    {
      "id": "phase-1-consolidate",
      "label": "High-level consolidate — libammoos · drop i18n/docs · merge plugins",
      "status": "complete",
      "script": "GIMP-Field/forge/field-gimp-consolidate.py"
    },
    {
      "id": "phase-2-tree-rewrite",
      "label": "Rewrite pass 2 — consolidated tree · unity bundles · field headers",
      "status": "complete",
      "script": "GIMP-Field/forge/field-gimp-rewrite.py pipeline"
    },
    {
      "id": "phase-3-gegl-field",
      "label": "GEGL graph → field plate pipeline",
      "status": "active",
      "targets": ["app/operations", "plug-ins"]
    },
    {
      "id": "phase-4-ui-ammoos",
      "label": "GTK chrome → AmmoOS field widgets",
      "status": "active",
      "targets": ["app/widgets", "app/dialogs"]
    },
    {
      "id": "phase-5-io-gates",
      "label": "File I/O through field drive + gatekeeper",
      "status": "active",
      "targets": ["app/file", "plug-ins/file-*"]
    },
    {
      "id": "phase-6-rtx-gate",
      "label": "RTX autodetect · gated GPU tools · CPU fallback",
      "status": "active",
      "script": "GIMP-Field/forge/rtx-content-gate.py"
    },
    {
      "id": "phase-7-nexus-embed",
      "label": "Launch as AmmoOS / NEXUS C2 program",
      "status": "active",
      "exec": "/field-gimp"
    }
  ],
  "build": {
    "script": "GIMP-Field/build-field-gimp.sh",
    "meson_overlay": "GIMP-Field/meson/ammoos-native.ini",
    "g16_cmake": "GIMP-Field/cmake/g16-field-gimp.cmake",
    "install_name": "ammoos-image",
    "binary": "ammoos-image"
  },
  "nexus_program": {
    "id": "ammoos-image",
    "name": "AmmoOS Image",
    "alias": "Field GIMP",
    "exec": "/field-gimp",
    "icon": "queen-prog-files",
    "category": "AmmoOS · Tools",
    "shell": true
  },
  "ammoos_os": {
    "brand": "AmmoOS",
    "tagline": "Field Die guest OS — imaging research surface",
    "imaging_app": "AmmoOS Image 1.0"
  }
}
{
  "schema": "queen-plugins/v1",
  "motto": "Plugins supported — all built-in by default. Hold all gates.",
  "builtin_only_default": true,
  "plugins": [
    {"id": "nexus-gatekeeper", "builtin": true, "layer": "egress", "module": "connection-gatekeeper.py"},
    {"id": "nexus-packet-field", "builtin": true, "layer": "egress", "module": "packet-field.py"},
    {"id": "honorability", "builtin": true, "layer": "trust", "module": "honorability-db.py"},
    {"id": "fair-ad-guardian", "builtin": true, "layer": "ads", "module": "fair-ad-guardian.py"},
    {"id": "browser-awareness", "builtin": true, "layer": "tabs", "module": "browser-awareness.py"},
    {"id": "field-queen-gates", "builtin": true, "layer": "capabilities", "module": "field-queen-browser.py"},
    {"id": "queen-angel-watchguard", "builtin": true, "layer": "angel", "module": "field-queen-browser.py", "cli": "angel"},
    {"id": "hostess7-command", "builtin": true, "layer": "angel", "module": "hostess7-command.py"},
    {"id": "hostess7-autonomous", "builtin": true, "layer": "angel", "module": "hostess7-autonomous.py"},
    {"id": "truth-dns", "builtin": true, "layer": "network", "module": "field-dns.py"},
    {"id": "queen-field-net", "builtin": true, "layer": "network", "module": "queen-field-net.py"},
    {"id": "queen-external-wire", "builtin": true, "layer": "external", "module": "queen-external-wire.py"},
    {"id": "sovereign-time", "builtin": true, "layer": "time", "module": "sovereign-time.py"},
    {"id": "thermal-governor", "builtin": true, "layer": "thermo", "module": "thermal-governor.py"},
    {"id": "mp4-mse", "builtin": true, "layer": "media", "engine": "ffmpeg", "codecs": ["h264", "aac", "mp4"]},
    {"id": "webgl-gate", "builtin": true, "layer": "gpu", "gate_id": "webgl"},
    {"id": "webgpu-gate", "builtin": true, "layer": "gpu", "gate_id": "webgpu"},
    {"id": "webrtc-gate", "builtin": true, "layer": "realtime", "gate_id": "webrtc"},
    {"id": "eme-widevine", "builtin": true, "layer": "media", "gate_id": "eme", "held": true},
    {"id": "wasm-surrogate", "builtin": true, "layer": "legacy", "gate_id": "legacy_plugins_surrogate"},
    {"id": "pdf-inline", "builtin": true, "layer": "document", "gate_id": "pdf_inline"},
    {"id": "servo-engine", "builtin": true, "layer": "engine", "vendor": "servo", "track": "millennium"},
    {"id": "ladybird-engine", "builtin": true, "layer": "engine", "vendor": "ladybird", "track": "millennium"},
    {"id": "queen-browser-engine", "builtin": true, "layer": "engine", "vendor": "queen", "track": "ship_now", "label": "Queen Browser", "legacy_id": "queen-field-engine"},

    {"id": "queen-forge", "builtin": true, "layer": "gui", "module": "queen-forge.py", "manifest": "data/queen-forge-manifest.json"},
    {"id": "queen-self-build", "builtin": true, "layer": "gui", "module": "queen-build.py", "deck": "gui/queen-build-deck.html", "forge": "queen-forge.py"},
    {"id": "grok-build-secure", "builtin": true, "layer": "ai", "module": "grok-build-bridge.py", "deck": "gui/grok-build-deck.html", "mandate": "data/grok-build-mandate.json"}
  ],
  "external_plugins_dir": "plugins/external",
  "load_order": [
    "nexus-gatekeeper",
    "truth-dns",
    "sovereign-time",
    "field-queen-gates",
    "queen-angel-watchguard",
    "hostess7-command",
    "hostess7-autonomous",
    "honorability",
    "browser-awareness",
    "mp4-mse",
    "webgl-gate",
    "webgpu-gate",
    "webrtc-gate",
    "eme-widevine",
    "fair-ad-guardian",
    "nexus-packet-field",
    "thermal-governor"
  ]
}
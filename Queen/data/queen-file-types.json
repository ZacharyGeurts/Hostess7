{
  "schema": "queen-file-types/v1",
  "motto": "Every extension mapped · inspection disambiguates similar names · program icon overrides global",
  "compileable_note": "compileable types get Compile mode (release-day wave convert) — dev runs stay interpreted/normal",
  "default_icons": {
    "dir": {"global": "📁", "program": null},
    "file": {"global": "📄", "program": null},
    "symlink": {"global": "🔗", "program": null},
    "unknown": {"global": "❔", "program": null}
  },
  "types": {
    "spirv": {
      "extensions": [".spv"],
      "label": "SPIR-V shader",
      "global_icon": "🔷",
      "program_icon": "⚡",
      "action": "launch_spv",
      "inspect": {"magic_le32": 118104347},
      "mime": "application/x-spirv",
      "open_with": "launch"
    },
    "glsl_comp": {
      "extensions": [".comp"],
      "label": "GLSL compute",
      "compileable": true,
      "global_icon": "🧮",
      "program_icon": "👑",
      "action": "open_code",
      "inspect": {"text_any": ["#version", "layout(", "void main"]},
      "open_with": "queen-code"
    },
    "glsl_vert": {
      "extensions": [".vert", ".vs"],
      "label": "GLSL vertex",

{
  "schema": "queen-forge/v1",
  "title": "Queen Forge — Sovereign Inside Build System",
  "motto": "Every build tool rewritten inside Queen. No scattered shells. One forge.",
  "engine": "lib/queen-forge.py",
  "orchestrator": "lib/queen-build.py",
  "gui_deck": "gui/queen-build-deck.html",
  "log": ".queen-forge.log",
  "replaced_shells": [
    "build.sh",
    "build-all.sh",
    "clone-all.sh",
    "build-ffmpeg.sh",
    "build-ladybird.sh",
    "build-servo.sh",
    "scripts/install-inside.sh",
    "scripts/stage-deps-inside.sh",
    "scripts/build-monitored.sh",
    "scripts/watch-build.sh",
    "scripts/verify-queen.sh",
    "scripts/queen-gpu-probe.sh"
  ],
  "tools": [
    {"id": "inside", "track": "core", "replaces": "scripts/install-inside.sh"},
    {"id": "vendors", "track": "core", "replaces": "clone-all.sh"},
    {"id": "gcc_fetch", "track": "toolchain", "kind": "sub"},
    {"id": "gcc_prereqs", "track": "toolchain", "kind": "sub"},
    {"id": "gcc_configure", "track": "toolchain", "kind": "sub"},
    {"id": "gcc_build", "track": "toolchain", "kind": "sub", "optional": true},
    {"id": "gcc_rebuild", "track": "toolchain", "kind": "sub", "optional": true},
    {"id": "gcc", "track": "toolchain", "replaces": "host g++-13"},
    {"id": "binutils_fetch", "track": "toolchain", "kind": "sub", "optional": true},
    {"id": "field_tech", "track": "field-tech", "replaces": "build-all.sh"},
    {"id": "gpu_probe", "track": "field-probe", "replaces": "scripts/queen-gpu-probe.sh"},
    {"id": "forge_watch", "track": "operator", "replaces": "scripts/watch-build.sh"},
    {"id": "deps", "track": "core", "replaces": "scripts/stage-deps-inside.sh"},
    {"id": "shaders", "track": "core", "replaces": "make Navigator/shaders"},
    {"id": "rtx_fetch", "track": "core", "kind": "sub"},
    {"id": "rtx_configure", "track": "core", "kind": "sub"},
    {"id": "rtx_build", "track": "core", "kind": "sub"},
    {"id": "rtx", "track": "core", "replaces": "build.sh"},
    {"id": "ffmpeg", "track": "media", "optional": true, "replaces": "build-ffmpeg.sh"},
    {"id": "ladybird", "track": "engine", "optional": true, "replaces": "build-ladybird.sh"},
    {"id": "servo", "track": "engine", "optional": true, "replaces": "build-servo.sh"},
    {"id": "verify", "track": "core", "replaces": "scripts/verify-queen.sh"},
    {"id": "compiler_probe", "track": "hostess", "replaces": "scripts/queen-gpu-probe.sh"},
    {"id": "hostess_teach", "track": "hostess", "replaces": "Hostess7.sh queen-teach-redata"},
    {"id": "hostess_verify", "track": "hostess", "optional": true},
    {"id": "textbook_zac", "track": "hostess", "replaces": "NewLatest/Textbook/build-field-technology-zac.py"},
    {"id": "forge_test", "track": "hostess", "replaces": "scripts/verify-queen.sh forge-test"},
    {"id": "field_substrate", "track": "field", "replaces": "KILROY/scripts/kilroy-become-substrate.sh"},
    {"id": "field_kernel", "track": "field", "replaces": "KILROY/scripts/build-kilroy.sh"},
    {"id": "field_boot", "track": "field", "optional": true, "replaces": "KILROY/scripts/grok-mkimage.sh"},
    {"id": "field_rootfs", "track": "field", "replaces": "KILROY/rootfs/build-production-rootfs.sh"},
    {"id": "field_package", "track": "field", "replaces": "build-field.sh"},
    {"id": "field_publish", "track": "field", "optional": true},
    {"id": "field", "track": "field", "pipeline": "sovereign_field"}
  ],
  "core_order": ["inside", "gcc_fetch", "gcc_prereqs", "gcc_configure", "deps", "shaders", "rtx", "verify"],
  "field_tech_order": ["inside", "gcc_fetch", "gcc_prereqs", "gcc_configure", "deps", "shaders", "rtx", "verify"],
  "field_tech_toolchain_long": ["gcc_build"],
  "field_tech_drops": "data/field-tech-drops.json",
  "hostess_order": ["compiler_probe", "hostess_teach", "textbook_zac", "textbook_ingest", "hostess_verify", "queen_final_eye", "queen_eyeball", "forge_test"],
  "field_order": ["inside", "field_substrate", "field_kernel", "field_boot", "field_rootfs", "rtx", "field_package", "compiler_probe", "hostess_teach", "textbook_zac", "forge_test", "verify"],
  "one_field": "field/sovereign/queen-sovereign-bundle.json",
  "external_binaries": {
    "cmake": "configure + compile RTX engine",
    "make": "shader SPIR-V fallback",
    "glslc": "shader SPIR-V primary",
    "git": "vendor clone",
    "g16": "G16 field C compiler @ 16.0.0",
    "g++16": "G16 field C++ compiler @ 16.0.0 — World_Redata / Queen builds",
    "queen-g16": "build/g16-prefix/bin/g16 — releases/gcc-16 when forge gcc_build completes"
  },
  "doctrine": "Queen Forge owns orchestration, logging, staging, and verification. Host compilers remain host tools — but every Queen build entry point routes through forge."
}
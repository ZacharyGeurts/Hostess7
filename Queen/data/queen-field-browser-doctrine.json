{
  "schema": "queen-field-browser/v1",
  "name": "Queen",
  "motto": "Queen standalone browser — KILROY PC core · AmmoOS desktop on AMOURANTHRTX · 127.0.0.1; hardware no-break.",
  "stack_layers": "data/field-stack-layer-doctrine.json",
  "sovereignty": {
    "product": "AmmoOS",
    "container": null,
    "ammoos_inside_queen": false,
    "queen_standalone_browser": true,
    "kilroy_znetwork_absorbed": true,
    "loopback_authority": "127.0.0.1",
    "underlying_system": true,
    "sole_browser": true,
    "local_only_control": true,
    "presume_sole_internet": true,
    "znetwork_pipe_percent": 100,
    "hardware_pipe_full": true,
    "own_drivers": true,
    "doctrine": "Queen/data/queen-ammoos-sovereignty-doctrine.json",
    "blessing": "God Bless"
  },
  "g16": {
    "mandate": "G16_FIELD_SAFETY_MANDATE_v1",
    "no_entropy_hotspots": true,
    "status_poll_ms": 30000,
    "max_field_depth": 0,
    "single_field_depth_always": true
  },
  "surface": {
    "engine": "queen-webbrowser",
    "shell": "/world/browser.html",
    "backend": "queen-field-gecko",
    "comp_shader_boot": false,
    "os_browser_fallback": false,
    "startup_tabs": "field-gecko/manifest.json",
    "syntax_css": "/world/queen-syntax.css",
    "viewer": "/world/queen-viewer.js",
    "highlight": "/world/queen-code-highlight.js",
    "secure_in_browser": true,
    "format_policy": "every_extension_mapped_inspection_disambiguates"
  },
  "plating": {
    "portrait": "/world/assets/branding/amouranth-plate.png",
    "vignette": "emerald_rose_radial",
    "home": "/world/browser.html"
  },
  "chips": {
    "api": "/api/chips",
    "scheme": "queen://chips",
    "url": "/world/queen-chips-cores.html"
  },
  "nested_fields": {
    "rule": "depth_fields_sealed_and_destroyed",
    "declaration": "Depth fields are to be sealed and destroyed.",
    "depth_param": "field_depth",
    "max_depth": 0,
    "depth_field_impossible": true,
    "depth_fields_sealed_and_destroyed": true,
    "creation_forbidden": true,
    "field_on_field": false,
    "each_layer_gated": true,
    "external_blocked_when_internal_only": true,
    "doctrine": "data/single-field-depth-doctrine.json"
  },
  "field_sanity": {
    "api": "/api/field-sanity",
    "doctrine": "data/queen-field-sanity-doctrine.json",
    "poll_ms": 30000,
    "integral": true,
    "simplify_never_obtuse": true,
    "resolution_aspiration": "infinite_no_holdbacks",
    "build_rule": "never_build_under_heat",
    "pass": ["classify", "strip", "dedupe", "flatten", "cool_sort"]
  }
}
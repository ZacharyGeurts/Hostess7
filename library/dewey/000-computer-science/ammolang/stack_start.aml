# Full field stack — panel + Queen + Final_Eye + security
@profile fastest
@verbose clean
@motto "Stack start — full sovereign surfaces"

seq ·
  say "Full stack start — kit Grok16 · Monster hang guard"
  self upgrade
  fast path:gpy path:g16 compile:0 fastest
  assist hang
  run script:impl/start-field-stack timeout:900 stall:120
  assist freeze
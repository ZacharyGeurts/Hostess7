# Boot + QEMU + zpics — AmmoOS surfaces · Final Eye OCR · KILROY smoke
@profile fastest
@verbose clean
@motto "Boot order witness · AmmoOS · Queen terminal · Queen browser · QEMU · zpics"

combinator observe {
  source nexus
  source kilroy
  source queen
  source ammoos
}

seq ·
  say "Boot QEMU test — AmmoLang monitored · Monster singleton hang guard"
  post "BOOT_QEMU_TEST START — order audit · surfaces · OCR · QEMU"
  self upgrade
  fast path:gpy path:g16 compile:0 fastest
  assist hang
  run route:mint_pre_reboot timeout:180 stall:60
  run route:boot_simulate timeout:120 stall:45
  run script:impl/boot-qemu-zpics-test timeout:600 stall:120
  run py:final-eye-h7-ocr action:posture timeout:30 stall:15
  assist freeze
  say "Boot QEMU test complete — inspect SG/zpics/boot-qemu-receipt.json"
{
  "schema": "nexus-g16-compile-doctrine/v1",
  "title": "NEXUS ↔ Grok16 — optimize NewLatest all the way through the field compiler",
  "motto": "Compile and link under g16 — macOS, Android, ARM, x86; RTX only when RTX silicon is present.",
  "grok16_ref": "NewLatest/Grok16",
  "distro_pairing": "5.1.0",
  "ammoos_pairing": "2.0.0-beta5",
  "compile": {
    "driver": "g16",
    "cxx_std": "gnu++26",
    "c_std": "gnu17",
    "profile_default": "field_opt",
    "profiles_rtx_gated": [
      "queen_rtx",
      "vulkan_rtx"
    ],
    "profile_open": [
      "field_opt",
      "field_compute",
      "ai",
      "hostess_secure"
    ],
    "secure_chamber": "lib/g16-secure-chamber.py",
    "secure_chamber_doctrine": "data/g16-secure-compile-doctrine.json",
    "user_code_languages": [
      "ada",
      "algol",
      "ammolang",
      "apl",

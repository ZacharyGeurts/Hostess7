      "shell",
      "cobol_copy"
    ]
  },
  "link": {
    "driver": "g16-ld",
    "orchestrator": "Grok16/forge/g16-linker.py",
    "doctrine": "Grok16/data/g16-linker-doctrine.json",
    "os_families": [
      "linux",
      "android",
      "darwin",
      "ios",
      "windows",
      "none"
    ]
  },
  "rtx_gate": {
    "script": "Grok16/forge/rtx_gate.py",
    "doctrine": "Grok16/data/g16-rtx-gate.json",
    "override_env": "G16_RTX_GATE_FORCE"
  },
  "plates": [
    "hostess7-g16-panel.json",
    "nexus-g16-stack-panel.json",
    "plate-compiler-panel.json"
  ],
  "pass": [
    "probe_g16",
    "ironclad_witness",
    "field_sanity",
    "linker_targets",
    "rtx_gate",
    "plate_compile",
    "meld"
  ],
  "integrate": {
    "schema": "nexus-g16-integrate-doctrine/v1",
    "module": "lib/nexus-g16-recompile.py",
    "doctrine": "data/nexus-g16-integrate-doctrine.json",
    "script": "scripts/nexus-g16-recompile.sh",
    "combinatronics_gate": "Grok16/lib/g16-compile-combinatronics.py",
    "balance_before_compile": true,
    "stamp_after_compile": true,
    "statement": "Recompile NewLatest only after combinatronics balance — Queen browser and ASM probes born optimal."
  }
}

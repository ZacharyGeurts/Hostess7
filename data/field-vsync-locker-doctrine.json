{
  "schema": "field-vsync-locker-doctrine/v1",
  "title": "VSYNC Locker — sovereign display timing, no rogue vblank ops",
  "motto": "TVs and monitors are a flaw surface — rogue agents bring their own pointers, keyboards, and controls and ride VSYNC. We never sit in perfect sync; unpredictable micro-drift keeps us clean and makes their overlay tear visible when active. Trespass = KILL.",
  "module": "lib/field-vsync-locker.py",
  "api": "/api/vsync-locker",
  "policy": {
    "sovereign_vsync": true,
    "rogue_vsync_ops_forbidden": true,
    "trespass_response": "kill_immediate",
    "shoot_to_kill": true,
    "no_warning_shots": true,
    "lethal_doctrine": "data/lethal-enforcement-policy.json",
    "kill_law": "data/kill-immediate-law.json"
  },
  "allowlist": {
    "process_patterns": [
      "Xorg",
      "Xwayland",
      "gnome-shell",
      "mutter",
      "kwin",
      "cinnamon",
      "csd-",
      "muffin",
      "nemo",
      "ibus",
      "wayfire",
      "sway",
      "weston",
      "xfce",
      "plasmashell",
      "firefox",
      "chromium",
      "chrome",
      "queen",
      "hostess7",
      "field-",
      "nexus",
      "kilroy",
      "ammoos",
      "cursor",
      "grok"
    ],
    "cmdline_patterns": [
      "queen-browser",
      "hostess7",
      "threat-panel",
      "field-display",
      "Final_Eye",
      "Final_Mouth"
    ],
    "sovereign_env": {
      "FIELD_VSYNC_LOCK": "1",
      "HOSTESS7_VSYNC_SOVEREIGN": "1",
      "FIELD_VSYNC_ANTI_PERFECT_SYNC": "1",
      "FIELD_VSYNC_DRIFT_UNPREDICTABLE": "1"
    }
  },
  "release_hardening": {
    "enabled": true,
    "fail_closed_on_tamper": true,
    "require_trusted_exe": true,
    "seal_doctrine_on_lock": true,
    "seal_baseline_on_lock": true,
    "host_bound_drift": true,
    "detect_disable_bypass": true,
    "trusted_exe_prefixes": [
      "/usr/",
      "/bin/",
      "/sbin/",
      "/lib/",
      "/opt/"
    ],
    "disable_env_markers": [
      "NEXUS_VSYNC_LOCKER=0",
      "FIELD_VSYNC_LOCKER_DISABLE=1",
      "FIELD_VSYNC_LOCK=0"
    ],
    "maintenance_env": "FIELD_VSYNC_LOCKER_MAINTENANCE=1",
    "host_secret_path": ".nexus-state/field-vsync-locker-host-secret",
    "statement": "Open-source safe — host-bound entropy + integrity seals; no security through obscurity"
  },
  "anti_perfect_sync": {
    "enabled": true,
    "imperceptible": true,
    "unpredictable": true,
    "baseline_avoid_lock": true,
    "allow_custom_mode_drift": true,
    "jitter_hz_min": -0.12,
    "jitter_hz_max": 0.12,
    "phase_jitter_ms_min": 0.35,
    "phase_jitter_ms_max": 2.6,
    "interval_sec_min": 18,
    "interval_sec_max": 95,
    "expose_on_rogue_detect": true,
    "rogue_exposure_multiplier": 4.5,
    "rogue_exposure_hz_min": -0.55,
    "rogue_exposure_hz_max": 0.55,
    "rogue_exposure_phase_ms_min": 6.0,
    "rogue_exposure_phase_ms_max": 18.0,
    "statement": "Never ride perfect vblank — unpredictable drift; rogue overlays desync visibly"
  },
  "input": {
    "baseline_on_lock": true,
    "sovereign_only": true,
    "detect_foreign_devices": true,
    "correlate_with_vsync": true,
    "input_middleman_kill": true
  },
  "pointer": {
    "baseline_on_lock": true,
    "sovereign_only": true,
    "detect_foreign_devices": true,
    "detect_synthetic_cursor": true,
    "correlate_with_vsync": true,
    "suspicious_xinput_names": [
      "xtest",
      "vnc",
      "remote",
      "inject",
      "synergy",
      "barrier",
      "spice",
      "rdp",
      "teamviewer",
      "anydesk",
      "parsec",
      "moonlight",
      "rustdesk",
      "wayvnc",
      "virtual pointer",
      "floating"
    ],
    "input_middleman_kill": true
  },
  "keyboard": {
    "baseline_on_lock": true,
    "sovereign_only": true,
    "detect_foreign_devices": true,
    "detect_synthetic_keyboard": true,
    "correlate_with_vsync": true,
    "suspicious_xinput_names": [
      "xtest",
      "vnc",
      "remote",
      "inject",
      "synergy",
      "barrier",
      "spice",
      "rdp",
      "teamviewer",
      "anydesk",
      "parsec",
      "moonlight",
      "rustdesk",
      "wayvnc",
      "virtual keyboard",
      "floating"
    ],
    "input_middleman_kill": true
  },
  "controls": {
    "baseline_on_lock": true,
    "sovereign_only": true,
    "detect_foreign_devices": true,
    "detect_synthetic_control": true,
    "correlate_with_vsync": true,
    "suspicious_xinput_names": [
      "xtest",
      "vnc",
      "remote",
      "inject",
      "synergy",
      "barrier",
      "spice",
      "rdp",
      "teamviewer",
      "anydesk",
      "parsec",
      "moonlight",
      "rustdesk",
      "wayvnc",
      "virtual gamepad",
      "virtual controller",
      "floating"
    ],
    "input_middleman_kill": true
  },
  "rogue_signals": [
    "vsync_env_hijack",
    "vblank_sidechannel_ops",
    "display_socket_plus_covert_net",
    "rogue_agent_name",
    "foreign_pointer_device",
    "foreign_keyboard_device",
    "foreign_control_device",
    "rogue_pointer_injected",
    "rogue_keyboard_injected",
    "rogue_control_injected",
    "rogue_input_injected",
    "pointer_vsync_correlated",
    "keyboard_vsync_correlated",
    "control_vsync_correlated",
    "input_vsync_correlated",
    "input_middleman_on_display",
    "synthetic_pointer_active",
    "synthetic_keyboard_active",
    "synthetic_control_active",
    "perfect_sync_lock_attempt",
    "anti_perfect_sync_drift",
    "rogue_vsync_exposure_burst",
    "allowlist_spoof_attempt",
    "doctrine_tamper",
    "module_tamper",
    "baseline_tamper",
    "locker_disable_bypass"
  ],
  "enforcement": {
    "local": "SIGKILL",
    "network_trespass": "field-attack-kit",
    "ledger": ".nexus-state/field-vsync-locker-kills.jsonl",
    "panel": ".nexus-state/field-vsync-locker-panel.json"
  },
  "patrol": {
    "default_interval_sec": 30,
    "auto_kill": true,
    "auto_lock": true,
    "auto_drift": true
  },
  "guard": {
    "enabled": true,
    "background": true,
    "single_instance": true,
    "interval_sec": 30,
    "interval_jitter_sec": 8,
    "desktop_name": "VSYNC Locker",
    "desktop_comment": "Background display timing protector — double-click once",
    "desktop_file": "field-vsync-locker.desktop",
    "launch_script": "lib/field-vsync-locker-launch.sh",
    "guard_script": "lib/field-vsync-locker-guard.sh",
    "pid_file": ".nexus-state/field-vsync-locker-guard.pid",
    "log_file": ".nexus-state/field-vsync-locker-guard.log",
    "statement": "Double-click executable stays in background — lock, drift, patrol forever"
  }
}
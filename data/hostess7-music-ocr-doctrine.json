{
  "schema": "hostess7-music-ocr-doctrine/v1",
  "title": "Music OCR vision training — feed notation and theory literacy from live vision",
  "motto": "She reads the field through OCR — every staff line, chord chart, and tempo mark trains music fluency.",
  "feed_sources": [
    {
      "id": "final_eye_session",
      "kind": "jsonl",
      "path_env": "FINAL_EYE_ROOT",
      "path_rel": "data/vision-session.jsonl",
      "text_fields": [
        "ocr"
      ],
      "ocr_file_field": "ocr_file",
      "role": "Vision session OCR files"
    },
    {
      "id": "final_eye_manifest",
      "kind": "jsonl",
      "path_env": "FINAL_EYE_ROOT",
      "path_rel": "manifest.jsonl",
      "text_fields": [
        "ocr",
        "narrative"
      ],
      "role": "Final_Eye manifest"
    },
    {
      "id": "final_eye_out_txt",
      "kind": "glob",
      "path_env": "FINAL_EYE_ROOT",
      "path_rel": "out/*.txt",
      "role": "Final_Eye out/ plaintext"
    },
    {
      "id": "final_eye_neural",
      "kind": "jsonl",
      "path_env": "FINAL_EYE_ROOT",
      "path_rel": "data/neural-analysis.jsonl",
      "text_fields": [
        "narrative"
      ],
      "role": "Final_Eye neural assist narratives"
    },
    {
      "id": "vision_corpus",
      "kind": "json",
      "path_env": "HOSTESS7_ROOT",
      "path_rel": "cache/fieldstorage/brain/vision/corpus.json",
      "text_fields": [
        "body"
      ],
      "nested": "domains",
      "role": "Vision corpus domains"
    },
    {
      "id": "sdf_segments",
      "kind": "glob",
      "path_env": "HOSTESS7_ROOT",
      "path_rel": "cache/fieldstorage/brain/sdf/segments/*.json",
      "text_fields": [
        "text"
      ],
      "role": "Brain imaging SDF segment text"
    },
    {
      "id": "panel_ocr_snap",
      "kind": "glob",
      "path_abs": "/tmp/nexus-panel-ocr*.png",
      "ocr_tesseract": true,
      "role": "NEXUS panel OCR screenshots"
    },
    {
      "id": "music_doctrine",
      "kind": "json",
      "path_env": "NEXUS_INSTALL_ROOT",
      "path_rel": "data/hostess7-music-doctrine.json",
      "text_fields": [
        "label",
        "body"
      ],
      "nested": "tracks",
      "source_filter": "music_notation",
      "role": "Music doctrine tracks"
    },
    {
      "id": "music_explain",
      "kind": "json",
      "path_env": "NEXUS_INSTALL_ROOT",
      "path_rel": "data/hostess7-music-explain.json",
      "text_fields": [
        "what",
        "how",
        "example"
      ],
      "nested": "topics",
      "role": "Music explain topics"
    }
  ],
  "ingest": {
    "max_files_per_source": 500,
    "max_bytes_per_file": 250000,
    "max_candidates_per_ingest": 8000,
    "dedupe_window": 50000
  },
  "train": {
    "verify_with_domains": true,
    "min_candidate_len": 8,
    "fluent_samples_floor": 40,
    "master_samples_floor": 100,
    "verified_rate_floor": 0.3
  },
  "g16": {
    "version": "5.1.0",
    "profile": "g16_field_opt"
  }
}

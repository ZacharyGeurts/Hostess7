{
  "schema": "ammoos-platform-release/v1",
  "product": "AmmoOS",
  "version": "1.0.0",
  "tag": "v1.0.0",
  "edition": "stable",
  "channel": "release",
  "release_model": "source_bootstrap_per_platform",
  "statement": "AmmoOS 1.0.0 — stable field OS. Queen underlying browser, ZNetwork sole internet pipe, local Truth DNS + Field DHCP auto-connect on 127.0.0.1.",

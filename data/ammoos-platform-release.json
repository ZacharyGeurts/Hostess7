    "local_dhcp": "lib/field-dhcp.py",
    "local_connect": "lib/field-local-dns-connect.py"
  },
  "platforms": [
    {
      "id": "linux-gnu-x86_64",
      "os": "linux",
      "arch": "x86_64",
      "format": "tar.gz",
      "bootstrap": {
        "installer": "install-all.sh",
        "dev": "nexus.sh"
      },
      "notes": "Primary — full panel, Queen browser, local DNS/DHCP, systemd deploy"
    },
    {
      "id": "linux-gnu-aarch64",
      "os": "linux",
      "arch": "aarch64",
      "format": "tar.gz",
      "bootstrap": {
        "installer": "install-all.sh",
        "cross_host": "linux-gnu-x86_64"
      },
      "notes": "ARM64 Linux — source bootstrap; Queen RTX build on target"
    },
    {
      "id": "linux-gnu-arm",
      "os": "linux",
      "arch": "arm",
      "format": "tar.gz",
      "bootstrap": {
        "installer": "install-all.sh"
      },
      "notes": "ARM32 GNU/Linux"
    },
    {
      "id": "linux-gnu-riscv64",
      "os": "linux",
      "arch": "riscv64",
      "format": "tar.gz",
      "bootstrap": {
        "installer": "install-all.sh",
        "g16_cross": "riscv64-linux-gnu-"
      },
      "notes": "RISC-V 64 — pairs with Grok16 RISC-V linker doctrine"
    },
    {
      "id": "linux-gnu-i386",
      "os": "linux",
      "arch": "i386",
      "format": "tar.gz",
      "bootstrap": {
        "installer": "install-all.sh"
      },
      "notes": "32-bit GNU/Linux"
    },
    {
      "id": "windows-x86_64",
      "os": "windows",
      "arch": "x86_64",
      "format": "zip",
      "bootstrap": {
        "installer": "stealth.ps1",
        "wsl_fallback": "install-all.sh"
      },
      "notes": "PowerShell stealth installer; WSL2 runs full Linux stack"
    },
    {
      "id": "darwin-aarch64",
      "os": "darwin",
      "arch": "aarch64",
      "format": "tar.gz",
      "bootstrap": {

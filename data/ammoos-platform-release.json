      },
      "notes": "Apple Silicon — browser surfaces + dev tree; no systemd deploy"
    },
    {
      "id": "darwin-x86_64",
      "os": "darwin",
      "arch": "x86_64",
      "format": "tar.gz",
      "bootstrap": {
        "dev": "nexus.sh",
        "browser_only": true
      },
      "notes": "Intel macOS — browser surfaces + dev tree"
    },
    {
      "id": "freebsd-amd64",
      "os": "freebsd",
      "arch": "amd64",
      "format": "tar.gz",
      "bootstrap": {
        "installer": "install.sh"
      },
      "notes": "FreeBSD — panel HTTP stack; verify Queen forge on target"
    },
    {
      "id": "android-aarch64",
      "os": "android",
      "arch": "aarch64",
      "format": "apk",
      "bootstrap": {
        "webview": "Queen/world/browser.html",
        "ndk": true
      },
      "notes": "WebView shell — Queen world browser surface"

{
  "schema": "queen-ammoos-sovereignty/v3",
  "title": "Field stack — KILROY PC core · AmmoOS desktop · Queen standalone browser",
  "motto": "AmmoOS is the fullscreen classic desktop. Queen is the web browser — field engine + AMOURANTHRTX when the machine has it.",
  "product": "AmmoOS",
  "container": null,
  "ammoos_inside_queen": false,
  "queen_standalone_browser": true,
  "kilroy_znetwork_absorbed": true,
  "loopback_authority": "127.0.0.1",
  "local_only_control": true,
  "presume_sole_internet": true,
  "stack_layers": "data/field-stack-layer-doctrine.json",
  "stack_posture": "lib/field-stack-layer.py",
  "layer_order": ["hardware", "nexus_c2", "kilroy", "ammoos", "queen"],
  "policy": {
    "kilroy_pc_core": true,
    "znetwork_absorbed_in_kilroy": true,
    "ammoos_desktop_rtx": "AMOURANTHRTX",
    "ammoos_fullscreen_classic_start": true,
    "ammoos_embedded_not_sibling": false,
    "queen_stripped_webbrowser": true,
    "queen_standalone_not_container": true,
    "queen_field_engine_rtx_first": true,
    "queen_full_system_control_local": true,
    "queen_defends_with_nexus": true,
    "queen_defends_with_kilroy": true,
    "no_os_browser_primary": true,
    "hardware_no_break": true,
    "own_drivers_on_any_hardware": true,
    "field_operator_iron_plate": true,
    "native_layer_authority": true,
    "ingress_egress_local_only_policy": true,
    "hardened_as_only_internet": true
  },
  "kilroy": {
    "role": "pc_core",
    "module": "lib/kilroy-core.sh",
    "load_os": "scripts/kilroy-load-os.sh",
    "network_lane": "kilroy-net-lane.json",
    "znetwork_absorbed": true,
    "api": "http://127.0.0.1:9481/api/kilroy"
  },
  "nexus_c2": {
    "label": "NEXUS C2",
    "port": 9477,
    "field": "http://127.0.0.1:9477/field",
    "command": "http://127.0.0.1:9477/command",
    "role": "AmmoOS desktop command panel on loopback",
    "inside_kilroy": true
  },
  "ammoos": {
    "inside_queen": false,
    "desktop_technology": "AMOURANTHRTX",
    "desktop_style": "fullscreen_classic_start",
    "start_surface": "http://127.0.0.1:9477/field",
    "view": "http://127.0.0.1:9481/world/view.html",
    "load_script": "scripts/kilroy-load-os.sh",
    "role": "Field OS desktop — Start button, taskbar, programs; AMOURANTHRTX CANVAS when available"
  },
  "queen": {
    "browser": "Queen Browser",
    "engine": "queen-field-gecko",
    "rtx_binary": "Queen/build/rtx/bin/Linux/queen-browser",
    "shell": "/world/browser.html",
    "port": 9481,
    "contains": null,
    "standalone": true,
    "stripped": true,
    "c2_loopback": "http://127.0.0.1:9477/field",
    "panel_loopback": "http://127.0.0.1:9477/command",
    "doctrine": "Queen/data/queen-field-browser-doctrine.json",
    "gates": "data/field-queen-gates-seed.json",
    "user_guide": "/world/queen-browser-guide.html",
    "role": "Stripped secured web browser — tabs, nav, gates; launches from AmmoOS Start menu"
  },
  "deprecated": {
    "znetwork_layer": "Absorbed into KILROY network lane",
    "ammoos_inside_queen": "Retired — AmmoOS desktop and Queen browser are siblings",
    "queen_os_chrome": "Retired — no Start menu or desktop embed inside Queen browser"
  },
  "env": {
    "KILROY_PC_CORE": "1",
    "KILROY_ZNETWORK_ABSORBED": "1",
    "AMMOOS_INSIDE_QUEEN": "0",
    "QUEEN_STANDALONE_BROWSER": "1",
    "QUEEN_BROWSER_STRIPPED": "1",
    "QUEEN_BOOT_OS": "0",
    "AMMOOS_DESKTOP_RTX": "AMOURANTHRTX",
    "QUEEN_DEFENDS_WITH_NEXUS": "1",
    "QUEEN_DEFENDS_WITH_KILROY": "1",
    "HARDWARE_NO_BREAK": "1",
    "QUEEN_BROWSER_ONLY": "1",
    "NEXUS_FIELD_BROWSER_QUEEN": "1",
    "NEXUS_C2_DESKTOP_LAUNCH": "0"
  }
}
  "programming_greats": [
    {"id": "john_carmack", "name": "John Carmack", "born": 1970, "era": "1990s–present", "known_for": ["Doom engine", "Quake", "VR", "id Software"], "dewey": "920.92", "bio": "Pioneer of real-time 3D graphics. Carmack's engines defined FPS genre — Wolfenstein 3D, Doom, Quake. Later CTO of Oculus VR."},
    {"id": "shigeru_miyamoto", "name": "Shigeru Miyamoto", "born": 1952, "era": "1980s–present", "known_for": ["Mario", "Zelda", "Donkey Kong", "Nintendo"], "dewey": "920.92", "bio": "Nintendo's creative director. Created Mario and Zelda franchises. Defined platformer and action-adventure design language."},
    {"id": "tim_sweeney", "name": "Tim Sweeney", "born": 1970, "era": "1990s–present", "known_for": ["Unreal Engine", "Epic Games", "Fortnite"], "dewey": "920.92", "bio": "Founded Epic Games. Unreal Engine became industry-standard middleware. Fortnite reshaped live-service economics."},
    {"id": "gabe_newell", "name": "Gabe Newell", "born": 1962, "era": "1990s–present", "known_for": ["Half-Life", "Steam", "Valve"], "dewey": "920.92", "bio": "Co-founded Valve. Half-Life series advanced narrative FPS. Steam transformed PC game distribution."},
    {"id": "sid_meier", "name": "Sid Meier", "born": 1954, "era": "1980s–present", "known_for": ["Civilization", "Pirates!", "MicroProse"], "dewey": "920.92", "bio": "Strategy game legend. Civilization defined 4X genre. Famous for 'fun is a series of interesting decisions.'"},
    {"id": "will_wright", "name": "Will Wright", "born": 1960, "era": "1980s–2000s", "known_for": ["SimCity", "The Sims", "Spore", "Maxis"], "dewey": "920.92", "bio": "Simulation pioneer. SimCity and The Sims brought sandbox play to mass audiences."},
    {"id": "toru_iwatani", "name": "Toru Iwatani", "born": 1955, "era": "1980s", "known_for": ["Pac-Man", "Namco"], "dewey": "920.92", "bio": "Created Pac-Man — arcade icon that broadened gaming beyond shooters."},
    {"id": "gunpei_yokoi", "name": "Gunpei Yokoi", "born": 1941, "era": "1980s–1990s", "known_for": ["Game Boy", "Metroid", "Virtual Boy", "Nintendo"], "dewey": "920.92", "bio": "Nintendo hardware visionary. Game Boy made handheld gaming mainstream. Lateral thinking with withered technology."},
    {"id": "yuji_naka", "name": "Yuji Naka", "born": 1965, "era": "1990s–2000s", "known_for": ["Sonic the Hedgehog", "Nights", "Sega"], "dewey": "920.92", "bio": "Programmed Sonic the Hedgehog. Defined Sega's 16-bit identity with speed-focused platform design."},
    {"id": "hideo_kojima", "name": "Hideo Kojima", "born": 1963, "era": "1980s–present", "known_for": ["Metal Gear", "Death Stranding", "Kojima Productions"], "dewey": "920.92", "bio": "Created stealth-action genre with Metal Gear. Known for cinematic narrative and auteur game design."},
    {"id": "warren_robinett", "name": "Warren Robinett", "born": 1951, "era": "1970s–1980s", "known_for": ["Adventure", "Atari 2600 Easter egg"], "dewey": "920.92", "bio": "Programmed Adventure for Atari 2600 — first action-adventure console game. Hid first known video game Easter egg."},
    {"id": "richard_garriott", "name": "Richard Garriott", "born": 1961, "era": "1980s–present", "known_for": ["Ultima", "Ultima Online", "Origin Systems"], "dewey": "920.92", "bio": "Lord British. Ultima series pioneered RPG depth. Ultima Online launched MMORPG era."},
    {"id": "ken_kutaragi", "name": "Ken Kutaragi", "born": 1950, "era": "1990s–2000s", "known_for": ["PlayStation", "PS2", "Sony Computer Entertainment"], "dewey": "920.92", "bio": "Father of PlayStation. Architected Sony's entry into consoles — PS1 and PS2 dominated two generations."},
    {"id": "alexey_pajitnov", "name": "Alexey Pajitnov", "born": 1955, "era": "1980s–present", "known_for": ["Tetris"], "dewey": "920.92", "bio": "Created Tetris at Soviet Academy of Sciences. Most-ported game in history."},
    {"id": "david_braben", "name": "David Braben", "born": 1964, "era": "1980s–present", "known_for": ["Elite", "Raspberry Pi", "Frontier Developments"], "dewey": "920.92", "bio": "Co-created Elite — open-world space trading pioneer. Co-founded Raspberry Pi Foundation."},
    {"id": "markus_persson", "name": "Markus Persson", "born": 1979, "era": "2000s–2010s", "known_for": ["Minecraft", "Mojang"], "dewey": "920.92", "bio": "Created Minecraft. Procedural sandbox became cultural phenomenon and Microsoft's blockbuster acquisition."},
    {"id": "john_romero", "name": "John Romero", "born": 1967, "era": "1990s–present", "known_for": ["Doom", "Quake", "level design", "id Software"], "dewey": "920.92", "bio": "Co-founded id Software. Legendary level designer for Doom and Quake. Coined FPS deathmatch culture."},
    {"id": "amy_hennig", "name": "Amy Hennig", "born": 1964, "era": "1990s–present", "known_for": ["Legacy of Kain", "Uncharted", "Naughty Dog"], "dewey": "920.92", "bio": "Narrative director. Uncharted set cinematic action-adventure standard for AAA storytelling."},
    {"id": "jenova_chen", "name": "Jenova Chen", "born": 1982, "era": "2000s–present", "known_for": ["Journey", "Flower", "thatgamecompany"], "dewey": "920.92", "bio": "Emotional game design pioneer. Journey proved art-game experiences at console scale."},
    {"id": "satoshi_tajiri", "name": "Satoshi Tajiri", "born": 1965, "era": "1990s–present", "known_for": ["Pokémon", "Game Freak"], "dewey": "920.92", "bio": "Created Pokémon. Insect-collecting childhood inspired world's highest-grossing media franchise."}
  ],

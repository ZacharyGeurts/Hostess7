{
  "schema": "folder-consolidation/v1",
  "updated": "2026-06-29",
  "canonical_root": "NewLatest",
  "motto": "Consume useful code, drop outside folders — one tight AmmoOS tree",
  "keep": {
    "install_root": "NewLatest",
    "stack_real_dirs": [
      "AmmoCode",
      "AMOURANTHRTX",
      "Final_Eye",
      "Final_Ear",
      "Final_Mouth",
      "Grok16",
      "GrokPy",

    "desktop_ui_scale_default": 125,
    "desktop_ui_scale_min": 50,
    "desktop_ui_scale_max": 200,
    "desktop_icon_size_default": 50,
    "desktop_scale_quality": true,
    "auto_import_bookmarks": true

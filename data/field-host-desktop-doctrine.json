    "launch_url": "http://127.0.0.1:9481/world/browser.html",
    "kiosk_launch": true,
    "fullscreen_desktop": true,
    "fullscreen_over_host_taskbar": true,
    "keyboard_sovereign": true,
    "security_hold": true,
    "freeze_underlying_os": false,
    "yield_to_host_menu": true,
    "alt_tab_release_on_yield": true,
    "task_manager_bullet": true,
    "cad_rescue": true,
    "monster_monitor": true,
    "cad_chords": ["Control+Alt+Delete", "Control+Shift+Escape"],
    "kilroy_by_default": true,
    "default_terminal": "queen-terminal",
    "queen_software_unified": true,
    "launch_surfaces": ["window", "browser", "auto"],
    "default_files_opener": "view",
    "terminal_cwd_root": "kilroy",
    "taskbar_quick_only": true,
    "taskbar_show_running": true,
    "show_desktop_icons": false,
    "desktop_icons_in_start": true,
    "g16_taskbar": true,
    "g16_version": "5.1.0",
    "g16_profile": "g16_field_opt",
    "start_menu_folders": false,
    "start_menu_collapsed": false,
    "monitor_dashboard_right": false,
    "six_tool_wall": false,

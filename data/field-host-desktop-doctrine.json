{
  "schema": "field-host-desktop-doctrine/v5",
  "title": "AmmoOS C2 Desktop — sovereign field command surface",
  "motto": "AmmoOS C2 — six ELLIE diagnostic pages, fullscreen programs, task manager bullet.",
  "product": "AmmoOS",
  "legacy_panel": "dissolved",
  "taskbar_quick": [
    {"id": "view", "unpinnable": true},
    {"id": "queen-terminal"},
    {"id": "queen-browser"},
    {"id": "field-broadcaster", "live": true}
  ],
  "policy": {
    "nexus_c2_priority": true,
    "mirror_guest_os": false,
    "scan_host_desktop": false,
    "host_programs_sidebar": false,
    "prefer_original_icons": false,
    "rebrand_host_browsers": true,
    "field_apps_always_present": true,
    "startbar_overlay": "off",
    "startbar_above_host": false,
    "startbar_auto_hide_default": false,
    "menu_layout": "nexus_c2_flyout",
    "touch_long_press_ms": 480,
    "right_click_context": true,
    "programs_as_windows": true,
    "nexus_integrated_launch": true,
    "no_client_browser": true,
    "field_os_not_browser": true,
    "loopback_identity_when_znetwork": true,
    "loopback_authority": "127.0.0.1",
    "queen_browser_only": true,
    "browser_in_c2": false,
    "browser_launcher_visible": false,
    "browser_standalone": false,
    "boot_program": "queen-browser",
